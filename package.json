{
  "name": "zoqr",
  "version": "0.1.0",
  "description": "ZoQR — API + Admin dashboard. Create QR codes, manage rich content (text, images, files, links), generate short URLs.",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "@types/qrcode": "^1.5.6",
    "hono": "^4.12.26",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
